---
// REQ-SITE-006 — final CTA with copy-paste install + first command.
const install = 'pip install taskship';
const firstRun = 'taskship plan "your product brief"';
---
<section class="section cta" id="install">
  <div class="container">
    <div class="cta__panel">
      <span class="eyebrow">Get started</span>
      <h2>Install TaskShip and plan your next release in a minute.</h2>
      <p class="cta__sub">Python 3.11+ and a Jira Cloud API token is all you need. No backend, no signup.</p>

      <div class="cta__cmds">
        <div class="cmd">
          <span><span class="cmd__prompt">$</span>{install}</span>
          <button data-copy={install} aria-label="Copy install command">Copy</button>
        </div>
        <div class="cmd">
          <span><span class="cmd__prompt">$</span>{firstRun}</span>
          <button data-copy={firstRun} aria-label="Copy first command">Copy</button>
        </div>
      </div>

      <div class="cta__steps">
        <span><b>1</b> Install with pip</span>
        <span><b>2</b> <code>taskship init</code> or <code>plan</code></span>
        <span><b>3</b> <code>taskship sync</code> to your board</span>
      </div>

      <div class="cta__actions">
        <a class="btn btn--primary" href="https://pypi.org/project/taskship/">Install from PyPI →</a>
        <a class="btn btn--ghost" href="https://github.com/selvakumarEsra/taskship">View on GitHub</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta__panel {
    background:
      radial-gradient(700px 260px at 12% 0%, #eeeefc 0%, rgba(238,238,252,0) 60%),
      #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow);
    padding: clamp(28px, 5vw, 56px);
    max-width: 820px;
    margin: 0 auto;
    text-align: center;
  }
  .cta__panel h2 { margin-top: 16px; }
  .cta__sub { color: var(--ink-muted); margin-top: 14px; font-size: 1.08rem; }
  .cta__cmds { display: grid; gap: 10px; max-width: 520px; margin: 28px auto 0; text-align: left; }
  .cmd span { white-space: nowrap; overflow-x: auto; }
  .cta__steps {
    display: flex; flex-wrap: wrap; justify-content: center; gap: 18px;
    margin-top: 22px; color: var(--ink-faint); font-size: 0.9rem;
  }
  .cta__steps b {
    display: inline-grid; place-items: center; width: 20px; height: 20px;
    border-radius: 50%; background: var(--brand-soft); color: var(--brand-ink);
    font-size: 0.75rem; margin-right: 6px;
  }
  .cta__steps code, .cta__panel code {
    font-family: var(--font-mono); font-size: 0.85em; color: var(--brand-ink);
    background: var(--brand-soft); padding: 1px 5px; border-radius: 5px;
  }
  .cta__actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; margin-top: 30px; }
</style>
