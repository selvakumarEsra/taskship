---
// REQ-SITE-004 — ordered workflow: brief → plan.yaml → dry-run → sync → status.
const steps = [
  { n: 1, cmd: 'taskship plan "…"', title: 'Describe the brief', body: 'A one-line product brief becomes a structured plan — epics by theme, a story per capability, a DevOps story per service, typed tasks attached.' },
  { n: 2, cmd: 'taskship review', title: 'Review the plan-as-code', body: 'The plan is a single plan.yaml with a stable local id per node. Read the tree, diff it, edit it, review it in a pull request.' },
  { n: 3, cmd: 'taskship sync --dry-run', title: 'Preview the sync', body: 'See exactly what would be created, updated, or skipped in Jira — before a single write. No surprises on the board.' },
  { n: 4, cmd: 'taskship sync', title: 'Sync to Jira, idempotently', body: 'Create / update / skip per node. Re-running never duplicates — it diffs against a content hash and patches only what changed.' },
  { n: 5, cmd: 'taskship status', title: 'Plan vs. reality', body: 'Pull live status, assignee and story points back from the board — a plan-vs-reality view that never overwrites your intent.' },
];
---
<section class="section" id="how">
  <div class="container">
    <div class="section__head">
      <span class="eyebrow">How it works</span>
      <h2>Brief in. Reviewable plan out. Jira in sync.</h2>
      <p>Five commands, one loop. Everything runs over the same engine whether you drive it from the CLI or an agent drives it over MCP.</p>
    </div>

    <div class="how">
      <ol class="how__steps">
        {steps.map((s) => (
          <li class="how__step">
            <span class="how__n">{s.n}</span>
            <div>
              <code class="how__cmd">{s.cmd}</code>
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>

      <aside class="how__aside">
        <figure class="how__code card">
          <figcaption>plan.yaml — the source of intent</figcaption>
          <pre><code><span class="y-key">product</span>: Checkout Revamp
<span class="y-key">jira_project</span>: CHK
<span class="y-key">epics</span>:
  - <span class="y-key">id</span>: guest-checkout
    <span class="y-key">title</span>: One-click guest checkout
    <span class="y-key">stories</span>:
      - <span class="y-key">id</span>: guest-flow
        <span class="y-key">title</span>: Guest checkout flow
        <span class="y-key">tasks</span>:
          - <span class="y-key">type</span>: biz-spec
            <span class="y-key">title</span>: Define requirements
          - <span class="y-key">type</span>: tech-spec
            <span class="y-key">subtype</span>: perf
            <span class="y-key">metrics</span>: {'{'} <span class="y-key">baseline</span>: 480ms, <span class="y-key">target</span>: 200ms {'}'}</code></pre>
        </figure>
        <div class="how__sync card">
          <figcaption>Re-run sync — it diffs, it doesn’t duplicate</figcaption>
          <div class="how__diff">
            <span><b class="d-skip">skip</b> guest-checkout <em>unchanged</em></span>
            <span><b class="d-upd">update</b> guest-flow <em>title changed → 1 field patched</em></span>
            <span><b class="d-new">create</b> guest-flow/qa-1 <em>new task</em></span>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .how { display: grid; gap: 40px; align-items: start; }
  .how__steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 26px; }
  .how__step { display: grid; grid-template-columns: 40px 1fr; gap: 16px; }
  .how__n {
    width: 38px; height: 38px; border-radius: 10px;
    display: grid; place-items: center; font-weight: 700;
    color: #fff; background: var(--brand); box-shadow: var(--shadow-sm);
  }
  .how__cmd {
    display: inline-block; font-family: var(--font-mono); font-size: 0.82rem;
    color: var(--brand-ink); background: var(--brand-soft); border: 1px solid #dcdcf7;
    padding: 2px 8px; border-radius: 6px; margin-bottom: 8px;
  }
  .how__step h3 { margin-bottom: 4px; }
  .how__step p { color: var(--ink-muted); font-size: 0.98rem; }

  .how__aside { display: grid; gap: 18px; position: sticky; top: 84px; }
  .how__code, .how__sync { padding: 0; overflow: hidden; }
  figcaption {
    font-family: var(--font-mono); font-size: 0.78rem; color: var(--ink-faint);
    padding: 12px 16px; border-bottom: 1px solid var(--border); background: var(--bg-soft);
  }
  .how__code pre {
    margin: 0; padding: 16px; overflow-x: auto;
    font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.6; color: var(--ink);
  }
  .y-key { color: var(--brand); }
  .how__diff { display: grid; gap: 8px; padding: 16px; font-family: var(--font-mono); font-size: 0.82rem; }
  .how__diff em { color: var(--ink-faint); font-style: normal; }
  .how__diff b { display: inline-block; width: 58px; }
  .d-skip { color: var(--ink-faint); }
  .d-upd { color: var(--warn); }
  .d-new { color: var(--ok); }

  @media (min-width: 940px) {
    .how { grid-template-columns: 1fr 1fr; gap: 56px; }
  }
</style>
