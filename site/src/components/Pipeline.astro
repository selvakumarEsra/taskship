---
// The brief → plan.yaml → Jira pipeline (REQ-SITE-002.A2).
const stages = [
  { key: 'brief', label: 'Brief', sub: 'Describe the product', tone: 'brief', glyph: '✍' },
  { key: 'plan', label: 'plan.yaml', sub: 'Reviewable · diffable', tone: 'plan', glyph: '◇' },
  { key: 'jira', label: 'Jira', sub: 'Idempotent sync', tone: 'jira', glyph: '▤' },
];
---
<figure class="pipe card" aria-label="TaskShip pipeline: brief to plan.yaml to Jira">
  <ol class="pipe__row">
    {stages.map((s, i) => (
      <>
        <li class={`pipe__stage pipe__stage--${s.tone}`}>
          <span class="pipe__glyph" aria-hidden="true">{s.glyph}</span>
          <span class="pipe__label">{s.label}</span>
          <span class="pipe__sub">{s.sub}</span>
        </li>
        {i < stages.length - 1 && (
          <li class="pipe__arrow" aria-hidden="true">→</li>
        )}
      </>
    ))}
  </ol>
  <figcaption class="pipe__cap">GitOps for product planning — regenerate, review in a PR, sync.</figcaption>
</figure>

<style>
  .pipe { padding: 20px; }
  .pipe__row {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; align-items: stretch; gap: 10px;
  }
  .pipe__stage {
    display: flex; flex-direction: column; gap: 2px;
    padding: 14px 16px; border-radius: 12px; border: 1px solid var(--border);
    background: var(--bg-soft); flex: 1; text-align: left;
  }
  .pipe__stage--brief { background: var(--stage-brief); }
  .pipe__stage--plan { background: var(--stage-plan); border-color: #dcdcf7; }
  .pipe__stage--jira { background: var(--stage-jira); border-color: #cfe4fb; }
  .pipe__glyph { font-size: 1.1rem; color: var(--brand); }
  .pipe__label { font-family: var(--font-mono); font-weight: 600; font-size: 1rem; }
  .pipe__sub { font-size: 0.82rem; color: var(--ink-faint); }
  .pipe__arrow {
    align-self: center; color: var(--brand); font-size: 1.3rem; font-weight: 700;
    transform: rotate(90deg);
  }
  .pipe__cap {
    margin-top: 14px; font-size: 0.85rem; color: var(--ink-faint);
    text-align: center;
  }
  @media (min-width: 520px) {
    .pipe__row { flex-direction: row; align-items: stretch; }
    .pipe__arrow { transform: none; }
  }
</style>
